<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force trailing slashes for static export directories to prevent 403 Forbidden
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # 2. Rewrite dynamic admin edit routes to the static placeholder edit index.html
  RewriteCond %{REQUEST_URI} !^/admin/songs/new/edit/?$
  RewriteCond %{REQUEST_URI} !^/admin/songs/placeholder/edit/?$
  RewriteRule ^admin/songs/([^/]+)/edit/?$ admin/songs/placeholder/edit/index.html [L]

  # 3. Rewrite all dynamic song detail routes that don't exist to the placeholder index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^songs/([^/]+)/?$ /songs/placeholder/index.html [L]

</IfModule>

# 4. Disable caching for HTML and JSON files to ensure updates are real-time
<FilesMatch "\.(html|json)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </IfModule>
</FilesMatch>
